<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="https://raw.githubusercontent.com/CANSpiNproject/canspin-schema/refs/heads/main/tei_canspin_texts.rng" type="application/xml" schematypens="http://relaxng.org/ns/structure/1.0"?>
<?xml-model href="https://raw.githubusercontent.com/CANSpiNproject/canspin-schema/refs/heads/main/tei_canspin_texts.rng" type="application/xml"
	schematypens="http://purl.oclc.org/dsdl/schematron"?>
<TEI xmlns="http://www.tei-c.org/ns/1.0">
  <!-- This is an example of encoding a single text for a CANSpiN subcorpus. -->
  <teiHeader>
    <fileDesc>
      <titleStmt>
        <title>title of the work</title>
        <author ref="#VIAF-Link">author surname, forename</author>
        <respStmt>
          <name>Editor forename surname</name>
          <resp>Editor</resp>
        </respStmt>
        <respStmt>
          <name>Editor forename surename</name>
          <resp>Editor</resp>
        </respStmt>
      </titleStmt>
      <extent>
        <!-- Simplest variant: Text content from text-body, separated by spaces. -->
        <measure unit="words">1200</measure>
      </extent>
      <publicationStmt>
        <distributor>CANSpiN project</distributor>
        <!-- Set the publication date when the file is published. -->
        <date when="2023">2023</date>
        <pubPlace>Rostock</pubPlace>
        <idno>CANSpiN-deu-20_001</idno>
        <!-- project internal IDs (and filenames) according to this pattern -->
        <!-- availability: if open licence, then CC-BY 4.0,
            else Copyright: restricted, for research use only -->
        <availability>
          <licence target="https://creativecommons.org/licenses/by/4.0/">CC-BY 4.0</licence>
        </availability>
      </publicationStmt>
      <sourceDesc>
        <!-- Cite sources: 
          1. Digital source (e.g., other corpus or epub) 
          2. Print source (what was the print template for the digital source? 
          If unknown, enter “unknown”)
          3. First edition -->
        <bibl type="digital"><!-- or type="print", type="first" -->
          <author>Author forename surname</author>
          <title>Title of the work</title>
          <pubPlace>
            <country ref="#Link-TGN"/>
            <settlement ref="#Link-TGN"/>
          </pubPlace>
          <!-- For the place of publication, we record the following details: 
            country and city/town. -->
          <publisher>publisher</publisher>
          <date when="1932">1932</date>
          <ref target="https://example.com/texts/title-work">Online-Version of the edition</ref>
          <!-- Of course, the link is only needed if it is a digital edition. If certain 
            information that a print publication has (e.g., location) is missing for 
            such a publication, the above can also be omitted: i.e., adapt the fields to 
            the type of publication. -->
        </bibl>
      </sourceDesc>
    </fileDesc>
    <profileDesc>
      <langUsage>
        <!-- we only indicate the main language of the text -->
        <language ident="deu"/>
        <!-- or spa -->
      </langUsage>
      <textClass>
        <keywords>
          <term type="genre">novel</term>
          <!-- reference year: what we consider to be the decisive year for the analysis:
            this may correspond to the year of first publication, or, if a text was published 
            posthumously, for example, and was written much earlier, it may correspond to the 
            year of its creation. -->
          <term type="reference-year">1850</term>
        </keywords>
      </textClass>
    </profileDesc>
    <revisionDesc>
      <!-- First entry here when the file is first created. Then always document changes here -->
      <change when="2023-12-01">first version</change>
      <change when="2023-12-06">second version, much has changed</change>
    </revisionDesc>
  </teiHeader>
  <!-- the basic structure of the main text is indicated here: -->
  <text xml:lang="deu">
    <body>
      <div type="part">
        <head>Part I</head>
        <div type="chapter">
          <head>Heading of chapter</head>
          <p>Lorem <hi>ipsum</hi>...</p>
          <!-- Verse lines with <l> -->
          <l>Verszeile</l>
          <!-- From the ELTEC-Schema:
                "The <p> element is used for everything which is typeset as a separate block 
                on the page, including both paragraphs and list items; 
                the <l >element is used for verse lines or similar, 
                typically set off from the rest of the text. 
                Illustrations and any associated text such as a title or heading are excluded. 
                Passages set as if in drama are not specially treated. -->
        </div>
      </div>
    </body>
  </text>
</TEI>
